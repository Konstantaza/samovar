import os
import glob
import sys

# Add src directory to PYTHONPATH to allow importing SamovaR modules
sys.path.append(os.path.abspath("src"))
from samovar.annotators_wrapper import get_annotator_instance

# Load configuration
configfile: "config_init.yaml"

# Get all samples from input directories
def get_samples():
    r1_files = glob.glob(os.path.join(config['r1_dir'], "*_R1.fastq"))
    return [os.path.basename(f).replace('_R1.fastq', '') for f in r1_files]

SAMPLES = get_samples()

# Initialize annotator instances once during DAG generation
ANNOTATORS = {}
for run_conf in config.get('run_config', []):
    run_name = run_conf['run_name']
    tool_type = run_conf['type']
    ANNOTATORS[run_name] = get_annotator_instance(tool_type, run_conf, config)


# Get all annotator outputs needed
def get_all_expected_outputs():
    """Generate a list of all expected output files across all annotators."""
    outputs = []
    
    # Iterate over the dictionary of instantiated annotator objects
    for run_name, annotator in ANNOTATORS.items():
        
        # Iterate over each biological sample
        for sample in SAMPLES:
            
            # Delegate the path generation to the specific annotator class
            expected_files = annotator.get_expected_outputs(sample, config['output_dir'])
            
            # Add the generated paths to our flat master list
            outputs.extend(expected_files)
            
    return outputs

# Main rule defining the target files for the pipeline
rule all:
    input:
        get_all_expected_outputs()


rule kraken2:
    input:
        r1 = f"{config['r1_dir']}/{{sample}}_R1.fastq",
        r2 = f"{config['r2_dir']}/{{sample}}_R2.fastq"
    output:
        report = f"{config['output_dir']}/{{sample}}_{{run_name}}.kraken2.report",
        out = f"{config['output_dir']}/{{sample}}_{{run_name}}.kraken2.out"
    params:
        cmd = lambda wildcards, input, output: ANNOTATORS[wildcards.run_name].get_snakemake_shell_cmd(
            input.r1, input.r2, [output.report, output.out]
        )
    shell:
        """
        mkdir -p $(dirname {output.report})
        {params.cmd}
        """

rule custom:
    input:
        r1 = f"{config['r1_dir']}/{{sample}}_R1.fastq",
        r2 = f"{config['r2_dir']}/{{sample}}_R2.fastq"
    output:
        out = f"{config['output_dir']}/{{sample}}_{{run_name}}.custom.out"
    params:
        cmd = lambda wildcards, input, output: ANNOTATORS[wildcards.run_name].get_snakemake_shell_cmd(
            input.r1, input.r2, [output.out]
        )
    shell:
        """
        mkdir -p $(dirname {output.out})
        {params.cmd}
        """

