        bowtie = f"{config['output_dir']}/{{sample}}_{{run_name}}.bowtie2.bz2"
    params:
        cmd = lambda wildcards, input, output: ANNOTATORS[wildcards.run_name].get_snakemake_shell_cmd(
            input.r1, input.r2, [output.out, output.raw, output.bowtie]
        )
    shell:
        """
        mkdir -p $(dirname {output.out})
        {params.cmd}
        """